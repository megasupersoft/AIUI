{
  "name": "aiui",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:server": "cd server && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build --workspaces --if-present",
    "build:nodes": "npm run build --workspace=packages/nodes",
    "build:canvas": "npm run build --workspace=packages/canvas"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.4.0"
  }
}
